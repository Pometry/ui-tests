    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Pometry/ui-tests.git"
    },
    "directories": {
        "test": "tests"
    },
    "scripts": {
        "format": "prettier --write .",
        "format-check": "prettier --check .",
        "eslint": "eslint . --report-unused-disable-directives --max-warnings 0 --fix",
